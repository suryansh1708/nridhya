{
  "name": "frontend-builder",
  "version": "1.0.0",
  "description": "Custom Static Site Generator",
  "scripts": {
    "build": "node build.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --coverage",
    "build:with-tests": "npm test && node build.js"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^9.1.2"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"],
    "collectCoverageFrom": ["build.js"],
    "coverageThreshold": {
      "global": {
        "functions": 50,
        "lines": 50
      }
    }
  }
}
